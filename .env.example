# Core Configuration
ENVIRONMENT=development

# MongoDB (Atlas Local includes Vector Search)
MONGO_URI=mongodb://admin:adminpassword@mongodb:27017/?authSource=admin
MONGO_DB_NAME=mitre_db

# Neo4j Graph Database
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword

# LLM / Embedding Integration (LM Studio or OpenAI-compatible Host/Container API)
LLM_API_BASE=http://host.docker.internal:1234/v1
LLM_MODEL_NAME=nomic-ai/nomic-embed-text-v1.5-GGUF
# Fallback to local CPU-based embedding generation if LM Studio is not accessible/configured
USE_LOCAL_EMBEDDING_FALLBACK=true

# Service Port Mappings
PORT_BACKEND=8000
PORT_FRONTEND=8080
BACKEND_URL=http://backend:8000
